  </ItemGroup>
  <ItemGroup>
    <Compile Include="db\connection.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="main.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="models\entities.py">
      <SubType>Code</SubType>
    </Compile>
